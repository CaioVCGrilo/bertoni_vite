RewriteEngine On
RewriteBase /

# Redirecionar acesso direto a .html para URL limpa
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?]
RewriteRule ^ %1 [R=301,L]

# Servir /pagina como /pagina.html internamente
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Configuração de MIME types
<IfModule mod_mime.c>
    AddType application/javascript .js .mjs
    AddType text/css .css
    AddType application/pdf .pdf
    AddType image/webp .webp
    AddType image/svg+xml .svg
    AddType application/json .json
</IfModule>

# Cache para arquivos estáticos
<IfModule mod_headers.c>
    # PDF sem cache - sempre verificar mudanças
    <FilesMatch "\.pdf$">
        Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
        Header unset ETag
        FileETag None
        Header set Access-Control-Expose-Headers "Last-Modified, Content-Length"
    </FilesMatch>

    # Outros arquivos com cache
    <FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|svg|webp|woff|woff2|ttf|eot)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
</IfModule>

# SPA fallback
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.html [L]